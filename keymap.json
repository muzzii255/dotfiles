[
    {
        "context": "Workspace",
        "bindings": {
            "alt-left": "workspace::ActivatePaneLeft",
            "alt-right": "workspace::ActivatePaneRight"
        }
    },
    {
        "context": "Editor",
        "bindings": {
            "alt-]": "editor::MovePageDown",
            "alt-[": "editor::MovePageUp",
            "ctrl ctrl": "editor::Hover",
            "alt-b": "editor::BlameHover",
            "ctrl-r": "editor::GoToDefinition",
            "ctrl-alt-f": "editor::RevealInFileManager",
            "alt-d": "editor::DeleteLine",
            "alt-a": ["editor::SelectToBeginningOfLine", { "stop_at_soft_wraps": true, "stop_at_indent": true }],
            "alt-s": ["editor::SelectToEndOfLine", { "stop_at_soft_wraps": true }],
            "shift shift": "outline::Toggle",
            "alt-e": ["editor::GoToDiagnostic", { "severity": { "min": "hint", "max": "error" } }],
            "alt-w": "diagnostics::Deploy",
            "alt-q": "editor::MoveToEnclosingBracket",
            "ctrl-alt-up": [
                "editor::MoveToBeginningOfLine",
                {
                    "stop_at_soft_wraps": true,
                    "stop_at_indent": true
                }
            ],
            "ctrl-alt-down": [
                "editor::MoveToEndOfLine",
                {
                    "stop_at_soft_wraps": true
                }
            ]
        }
    }
]
